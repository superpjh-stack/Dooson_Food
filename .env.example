# 두손푸드 AI-MES 환경변수 템플릿
# 실제 값은 .env.local에 설정하세요 (Git 제외)
# openssl rand -base64 32 으로 시크릿 생성

# ===== App =====
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ===== Database (PostgreSQL + TimescaleDB) =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dooson_mes
DB_USER=mes_user
DB_PASSWORD=
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ===== Redis =====
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ===== Auth (JWT) =====
AUTH_SECRET=
AUTH_ACCESS_TOKEN_EXPIRE=3600
AUTH_REFRESH_TOKEN_EXPIRE=604800

# ===== Storage (MinIO / S3 호환) =====
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET_XRAY=dooson-xray
STORAGE_BUCKET_REPORTS=dooson-reports
STORAGE_BUCKET_ML=dooson-ml-data

# ===== IoT / MQTT =====
IOT_MQTT_HOST=localhost
IOT_MQTT_PORT=1883
IOT_MQTT_USERNAME=
IOT_MQTT_PASSWORD=
IOT_MQTT_TOPIC_PREFIX=dooson/mes

# ===== AI / LLM =====
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# ===== ML 추론 서비스 =====
ML_INFERENCE_URL=http://localhost:8001
ML_MODEL_PATH=/models
ML_CONFIDENCE_THRESHOLD=0.6

# ===== Vector DB (RAG) =====
VECTOR_DB_URL=http://localhost:6333
VECTOR_COLLECTION_HACCP=haccp-docs

# ===== Monitoring =====
SENTRY_DSN=
GRAFANA_URL=http://localhost:3001
